{
  "name": "vocal-ai",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=22.0.0 <23",
    "pnpm": "9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @voice/mobile dev",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:scripts": "jest --config scripts/jest.config.js scripts/",
    "check:env": "tsx scripts/check-env-drift.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:fix": "eslint . --fix",
    "prepare": "lefthook install || true"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^6.0.2",
    "prettier": "^3",
    "eslint": "^9",
    "typescript-eslint": "^8",
    "eslint-config-prettier": "^9",
    "lefthook": "^1"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
