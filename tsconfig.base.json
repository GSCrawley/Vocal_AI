{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "ignoreDeprecations": [],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@voice/shared-types": [
        "packages/shared-types/src"
      ],
      "@voice/content-schema": [
        "packages/content-schema/src"
      ],
      "@voice/exercise-engine": [
        "packages/exercise-engine/src"
      ],
      "@voice/coaching-rules": [
        "packages/coaching-rules/src"
      ],
      "@voice/audio-metrics": [
        "packages/audio-metrics/src"
      ],
      "@voice/ui-tokens": [
        "packages/ui-tokens/src"
      ],
      "@voice/avatar-state": [
        "packages/avatar-state/src"
      ],
      "@voice/curriculum": [
        "packages/curriculum/src"
      ],
      "@voice/karaoke-engine": [
        "packages/karaoke-engine/src"
      ],
      "@voice/reward-engine": [
        "packages/reward-engine/src"
      ],
      "@voice/speaking-metrics": [
        "packages/speaking-metrics/src"
      ]
    }
  }
}
