{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "declaration": true,
    "forceConsistentCasingInFileNames": true,

    "paths": {
        "@voice/*": ["packages/*/src"]
    }
}
}
