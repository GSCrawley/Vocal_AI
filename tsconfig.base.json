{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@vocal-ai/shared-types": ["packages/shared-types/src"],
      "@vocal-ai/content-schema": ["packages/content-schema/src"],
      "@vocal-ai/exercise-engine": ["packages/exercise-engine/src"],
      "@vocal-ai/coaching-rules": ["packages/coaching-rules/src"],
      "@vocal-ai/audio-metrics": ["packages/audio-metrics/src"],
      "@vocal-ai/ui-tokens": ["packages/ui-tokens/src"]
    }
  }
}
