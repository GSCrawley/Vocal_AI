{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "ignoreDeprecations": "6.0",
    "declaration": true,
    "composite": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.test.ts", 
    "src/**/__tests__/**", 
    "dist", 
    "node_modules"
  ]
}