# ──────────────────────────────────────────────
# Node / runtime
# ──────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000

# ──────────────────────────────────────────────
# Supabase — Auth, Postgres, Storage, Realtime
# ──────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=     # server-side only; never ship to mobile
DATABASE_URL=                  # Postgres connection string

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ──────────────────────────────────────────────
# Redis (Render Valkey)
# ──────────────────────────────────────────────
REDIS_URL=

# ──────────────────────────────────────────────
# Sentry — Error Monitoring
# ──────────────────────────────────────────────
SENTRY_DSN_API=
SENTRY_DSN_WORKERS=
EXPO_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# CI-only — used to upload source maps
SENTRY_AUTH_TOKEN=
SENTRY_ORG=dominican-university-of-cal-s0
SENTRY_PROJECT_API=voice-api
SENTRY_PROJECT_WORKERS=voice-workers
SENTRY_PROJECT_MOBILE=voice-mobile

# ──────────────────────────────────────────────
# Better Stack — Log streaming destination
# ──────────────────────────────────────────────
# Configured in Render workspace settings, not consumed by app code.
# Listed here only so contributors know it exists.
# BETTER_STACK_SOURCE_TOKEN=   (workspace-level in Render)

# ──────────────────────────────────────────────
# Expo / EAS
# ──────────────────────────────────────────────
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# ──────────────────────────────────────────────
# Phase 2 providers (not active yet — leave blank)
# ──────────────────────────────────────────────
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
EXPO_PUSH_ACCESS_TOKEN=