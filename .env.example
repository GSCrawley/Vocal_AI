# ──────────────────────────────────────────────
# Node / runtime
# ──────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000
APP_ENV=

# ──────────────────────────────────────────────
# Auth/secrets
# ──────────────────────────────────────────────
SUPABASE_JWT_SECRET=
INTERNAL_SERVICE_TOKEN=

# ──────────────────────────────────────────────
# Supabase — Auth, Postgres, Storage, Realtime
# ──────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
SUPABASE_STORAGE_BUCKET_AUDIO=
SUPABASE_STORAGE_BUCKET_KARAOKE=
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ──────────────────────────────────────────────
# Redis (Render Valkey)
# ──────────────────────────────────────────────
REDIS_URL=

# ──────────────────────────────────────────────
# Sentry — Error Monitoring
# ──────────────────────────────────────────────
SENTRY_DSN=
SENTRY_DSN_API=
SENTRY_DSN_WORKERS=
EXPO_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=dominican-university-of-cal-s0
SENTRY_PROJECT_API=voice-api
SENTRY_PROJECT_WORKERS=voice-workers
SENTRY_PROJECT_MOBILE=voice-mobile

# ──────────────────────────────────────────────
# Expo / EAS
# ──────────────────────────────────────────────
EXPO_ACCESS_TOKEN=
EXPO_PROJECT_ID=
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=
API_BASE_URL=

# ──────────────────────────────────────────────
# Feature flags
# ──────────────────────────────────────────────
FEATURE_KARAOKE_MODE=
FEATURE_STYLE_PACKS=
FEATURE_PUSH_NOTIFICATIONS=
FEATURE_REALTIME_FILLER_DETECTION=
FEATURE_AVATAR_TTS=
AUDIO_STORAGE_OPT_IN_DEFAULT=

# ──────────────────────────────────────────────
# Phase 2 providers (not active yet — leave blank)
# ──────────────────────────────────────────────
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

ANALYTICS_WORKER_HEARTBEAT_LOGS=
NOTIFICATION_WORKER_HEARTBEAT_LOGS=
